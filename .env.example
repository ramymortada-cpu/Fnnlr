# Control-plane database — the ONLY shared DB. Holds tenant registry + routing + anonymized aggregates.
CONTROL_PLANE_DATABASE_URL=postgres://fnnlr_control:password@localhost:5432/fnnlr_control

# An admin Postgres connection that is allowed to CREATE DATABASE and CREATE ROLE.
# Used ONLY by the provisioning service to spin up a new dedicated DB per tenant.
TENANT_DB_ADMIN_URL=postgres://fnnlr_admin:password@localhost:5432/postgres

# The Postgres host/port where tenant databases are created (can differ from control-plane host).
TENANT_DB_HOST=localhost
TENANT_DB_PORT=5432

# Prefix for generated tenant database names and roles.
TENANT_DB_PREFIX=fnnlr_tenant

# Encryption key for tenant DB credentials stored in the control-plane (use KMS in production).
TENANT_CREDENTIAL_ENCRYPTION_KEY=change-me-32-byte-key-in-production
