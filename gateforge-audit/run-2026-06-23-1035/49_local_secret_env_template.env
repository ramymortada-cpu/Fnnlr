# GateForge local secret import template

# Generated: 2026-07-01T17:38:49.413Z

# Fill this file outside git, then run:

# npm run gateforge:import-local-secrets -- --env-file /secure/path/fnnlr-staging.env --require-all

# Do not commit a filled copy of this file.



# Attestation options: at least one must be real and valid.

# Optional raw hosted staging evidence packet JSON. Use B64 instead when uploading to GitHub.
# Validation: JSON object with HOSTED_STAGING or PRODUCTION_READ_ONLY evidence and PASS items.
# Required: ONE_OF_ATTESTATION_OPTIONS
GATEFORGE_HOSTED_STAGING_ATTESTATION_JSON=REPLACE_WITH_HOSTED_STAGING_ATTESTATION_JSON

# Preferred base64 encoded hosted staging evidence packet.
# Validation: Base64 text that decodes to a valid hosted staging attestation packet.
# Required: ONE_OF_ATTESTATION_OPTIONS
GATEFORGE_HOSTED_STAGING_ATTESTATION_B64=REPLACE_WITH_HOSTED_STAGING_ATTESTATION_B64



# Runtime secrets: every runtime secret is required for hosted GA evidence.

# Staging control-plane Postgres URL.
# Validation: postgres/postgresql URL with username, password, and host.
# Required: YES
CONTROL_PLANE_DATABASE_URL=REPLACE_WITH_STAGING_CONTROL_PLANE_DATABASE_URL

# Staging tenant database admin URL with create/drop permissions.
# Validation: postgres/postgresql URL with username, password, and host.
# Required: YES
TENANT_DB_ADMIN_URL=REPLACE_WITH_STAGING_TENANT_DB_ADMIN_URL

# Staging tenant database host only.
# Validation: Host only; no protocol, credentials, or path.
# Required: YES
TENANT_DB_HOST=REPLACE_WITH_STAGING_TENANT_DB_HOST

# Staging-only tenant credential encryption key.
# Validation: At least 24 characters.
# Required: YES
TENANT_CREDENTIAL_ENCRYPTION_KEY=REPLACE_WITH_STAGING_TENANT_CREDENTIAL_ENCRYPTION_KEY

# Staging-only integration secret encryption key.
# Validation: At least 24 characters.
# Required: YES
INTEGRATION_ENCRYPTION_KEY=REPLACE_WITH_STAGING_INTEGRATION_ENCRYPTION_KEY

# Staging cron authentication secret.
# Validation: At least 24 characters.
# Required: YES
FNNLR_CRON_SECRET=REPLACE_WITH_STAGING_FNNLR_CRON_SECRET

# Staging admin MFA encryption key.
# Validation: At least 24 characters.
# Required: YES
AUTH_MFA_ENCRYPTION_KEY=REPLACE_WITH_STAGING_AUTH_MFA_ENCRYPTION_KEY

# Approved staging per-tenant AI daily spend cap.
# Validation: Positive number.
# Required: YES
FNNLR_AI_TENANT_DAILY_USD_CAP=REPLACE_WITH_STAGING_AI_TENANT_DAILY_USD_CAP

# Approved staging global AI daily spend cap.
# Validation: Positive number.
# Required: YES
FNNLR_AI_GLOBAL_DAILY_USD_CAP=REPLACE_WITH_STAGING_AI_GLOBAL_DAILY_USD_CAP

# Staging Sentry or equivalent error monitoring DSN.
# Validation: HTTPS DSN.
# Required: YES
SENTRY_DSN=REPLACE_WITH_STAGING_SENTRY_DSN

# Public staging /health uptime monitor URL.
# Validation: HTTPS URL.
# Required: YES
UPTIME_HEALTHCHECK_URL=REPLACE_WITH_STAGING_UPTIME_HEALTHCHECK_URL

# Operations email address for staging alerts.
# Validation: Valid email address.
# Required: YES
ALERT_EMAIL_TO=REPLACE_WITH_STAGING_ALERT_EMAIL_TO

# Staging alert webhook URL for runtime failure alerts.
# Validation: HTTPS URL.
# Required: YES
ALERT_WEBHOOK_URL=REPLACE_WITH_STAGING_ALERT_WEBHOOK_URL

# Staging transactional email provider key.
# Validation: Non-trivial provider API key.
# Required: YES
RESEND_API_KEY=REPLACE_WITH_STAGING_RESEND_API_KEY

# Verified staging transactional sender address.
# Validation: Valid email address.
# Required: YES
EMAIL_FROM=REPLACE_WITH_STAGING_EMAIL_FROM

# Support reply-to mailbox for staging emails.
# Validation: Valid email address.
# Required: YES
EMAIL_REPLY_TO=REPLACE_WITH_STAGING_EMAIL_REPLY_TO

# Capped staging Anthropic API key.
# Validation: Non-trivial provider API key.
# Required: YES
ANTHROPIC_API_KEY=REPLACE_WITH_STAGING_ANTHROPIC_API_KEY
