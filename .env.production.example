# fnnlr — production environment template
# Copy to .env.production and fill real values. NEVER commit real secrets.
# Generated from ENV_SPEC (the single source of truth). Do not hand-edit the var list.

# APP_BASE_URL: public base URL used in customer-facing links.
APP_BASE_URL=https://app.your-domain.com

# API_BASE_URL: public base URL used in customer-facing links.
API_BASE_URL=https://api.your-domain.com

# [REQUIRED in production] Must be "production" in prod; gates fail-closed paths.
#   fail-closed: Without it, fail-closed checks (encryption, dev trust) do not engage.
NODE_ENV=production

# [REQUIRED in production] Control-plane Postgres (tenants, auth, sessions, public codes, routes).
#   fail-closed: No control DB → no auth, no tenant resolution. Hard fail.
CONTROL_PLANE_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/fnnlr_control

# [REQUIRED in production] Admin connection used to CREATE per-tenant databases/roles.
#   fail-closed: Provisioning impossible without it.
TENANT_DB_ADMIN_URL=postgresql://ADMIN:PASSWORD@HOST:5432/postgres

# [REQUIRED in production] Host for per-tenant DB connection strings.
TENANT_DB_HOST=your-db-host

# [optional] Port for per-tenant DB connections (defaults to 5432).
TENANT_DB_PORT=5432

# [optional] Name prefix for provisioned tenant databases.
TENANT_DB_PREFIX=fnnlr_tenant_

# [REQUIRED in production] AES key for tenant DB credentials at rest.
#   fail-closed: In production, storing a tenant credential throws if absent (no plaintext).
TENANT_CREDENTIAL_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_KEY__________!

# [REQUIRED in production] AES key for integration secrets (webhook/HMAC) at rest.
#   fail-closed: In production, encryptSecret throws if absent (no plaintext credentials).
INTEGRATION_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_KEY__________!

# [REQUIRED in production] Shared secret required on /internal/cron/* calls.
#   fail-closed: Cron endpoints reject all calls (401) when unset — jobs cannot run, but nothing is exposed.
FNNLR_CRON_SECRET=CHANGE_ME_RANDOM_LONG_STRING

# [optional] Enables real LLM generation; without it, AI features run in degraded fallback mode.
#   fail-closed: AI outputs are marked degraded; no crash.
ANTHROPIC_API_KEY=

# [REQUIRED before GA with paid AI] AI spend controls. Production requires at
# least one positive cap unless AI calls are intentionally disabled/degraded.
FNNLR_AI_KILL_SWITCH=false
FNNLR_AI_REQUIRE_BUDGET=true
FNNLR_AI_GLOBAL_DAILY_USD_CAP=
FNNLR_AI_TENANT_DAILY_USD_CAP=
FNNLR_AI_ESTIMATED_USD_PER_1M_TOKENS=15

# [REQUIRED for admin GA] MFA secret encryption key for TOTP setup.
AUTH_MFA_ENCRYPTION_KEY=CHANGE_ME_32_BYTE_KEY__________!

# [REQUIRED for transactional email evidence] Resend staging/default provider.
RESEND_API_KEY=
EMAIL_FROM=fnnlr <noreply@your-domain.com>
EMAIL_REPLY_TO=support@your-domain.com

# [REQUIRED for production observability evidence]
SENTRY_DSN=
UPTIME_HEALTHCHECK_URL=https://api.your-domain.com/health
ALERT_EMAIL_TO=ops@your-domain.com
ALERT_WEBHOOK_URL=

# [optional] Port the API server listens on (default 8787).
API_PORT=8787

# [optional] In-process scheduler tick interval (if the embedded scheduler is used).
SCHEDULER_INTERVAL_MS=

# [optional] Global kill-switch: "true" makes cron endpoints return 503.
FNNLR_DISABLE_JOBS=

# [DEV ONLY — leave unset in production] DEV ONLY. Allows x-tenant-id header trust for local testing.
#   fail-closed: MUST be unset/false in production; otherwise the API would trust a client tenant header.
# FNNLR_DEV_MODE=
